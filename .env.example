# ─── SERVER ─────────────────────────────────────────
PORT=3000

# ─── SENDER IDENTITY ─────────────────────────────────
SMTP_FROM=contact@yourdomain.com
SMTP_FROM_NAME=Your Name from Company

# ─── RESEND (Sending Emails) ─────────────────────────
# Get key at https://resend.com/api-keys
# Verify domain at https://resend.com/domains (add SPF, DKIM, DMARC)
RESEND_API_KEY=re_your_resend_api_key_here

# ─── IMAP (Reading Replies) ──────────────────────────
# Resend only sends — you still need IMAP to read replies
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=contact@yourdomain.com
IMAP_PASS="your_email_password"

# ─── OPENROUTER AI ───────────────────────────────────
# Get key at https://openrouter.ai/keys
# Free models available (e.g. minimax/minimax-m2.5:free)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ─── SCHEDULING ──────────────────────────────────────
# Cron format: minute hour day month weekday
# "0 9 * * *" = every day at 9:00 AM
CRON_SCHEDULE=0 9 * * *

# ─── LIMITS ──────────────────────────────────────────
# Max initial outreach emails to send per daily run (keeps deliverability high)
MAX_OUTREACH_PER_DAY=10

# ─── COMMON IMAP PRESETS ─────────────────────────────
# Gmail / Google Workspace:
#   IMAP_HOST=imap.gmail.com  IMAP_PORT=993  IMAP_SECURE=true
#   (Use App Password, not your main password)
#
# Namecheap Private Email:
#   IMAP_HOST=mail.privateemail.com  IMAP_PORT=993  IMAP_SECURE=true
#
# cPanel / Hostinger:
#   IMAP_HOST=mail.yourdomain.com  IMAP_PORT=993  IMAP_SECURE=true
#
# Outlook / Microsoft 365:
#   IMAP_HOST=outlook.office365.com  IMAP_PORT=993  IMAP_SECURE=true
